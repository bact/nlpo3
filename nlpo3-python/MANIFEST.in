include LICENSE README.md pyproject.toml Cargo.toml
recursive-include src *

# Include parent Rust crate sources and embedded ONNX model required by the
# deepcut extension.  The nlpO3 Python binding depends on the nlpo3 Rust
# crate via a path dependency (../), so both must be present when building
# from an sdist.  This package is designed for monorepo builds; users
# building from PyPI source distributions should use a binary wheel instead.
graft ../src
include ../Cargo.toml
include ../Cargo.lock
graft ../model

# Ensure the Python package files are included in the sdist
graft nlpo3

# Include PEP 561 marker and type stubs for compiled extension
include nlpo3/py.typed
recursive-include nlpo3 *.pyi

# Exclude test notebooks and tests from the sdist to keep it small
prune tests
prune notebooks
