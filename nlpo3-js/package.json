{
  "name": "nlpo3",
  "version": "2.0.0",
  "description": "nlpO3 Thai language tokenizer and word segmentation library for JavaScript (ESM) with TypeScript types",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PyThaiNLP/nlpo3.git"
  },
  "keywords": [
    "thai",
    "tokenizer",
    "tokenization",
    "text-processing",
    "nlp",
    "natural-language-processing",
    "word-segmentation",
    "pythainlp",
    "rust"
  ],
  "author": {
    "name": "Thanathip Suntorntip Gorlph",
    "url": "https://github.com/Gorlph/"
  },
  "contributors": [
    {
      "name": "Arthit Suriyawongkul",
      "url": "https://github.com/bact"
    }
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/PyThaiNLP/nlpo3/issues"
  },
  "homepage": "https://github.com/PyThaiNLP/nlpo3/tree/main/nlpo3-js",
  "type": "module",
  "main": "./nlpo3/index.js",
  "module": "./nlpo3/index.js",
  "types": "./nlpo3/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./nlpo3/index.d.ts",
      "import": "./nlpo3/index.js",
      "default": "./nlpo3/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "cargo-cp-artifact -a cdylib nlpo3_js ./nlpo3/rust_mod.node -- cargo build --message-format=json-render-diagnostics",
    "release": "cargo-cp-artifact -a cdylib nlpo3_js ./nlpo3/rust_mod.node -- cargo build --release --message-format=json-render-diagnostics && tsc",
    "prepare": "npm run build",
    "prepack": "npm run release",
    "test": "npm run build && tsc && node --test tests/test_tokenizers.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cargo-cp-artifact": "^0.1",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "Cargo.toml",
    "src/**",
    "nlpo3/index.js",
    "nlpo3/index.d.ts",
    "nlpo3/rust_mod.d.ts",
    "nlpo3/rust_mod.node",
    "README.md",
    "LICENSE"
  ]
}
