{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": false,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "nlpo3",
    "rootDir": "nlpo3"
  },
  "include": ["nlpo3/**/*.ts"],
  "exclude": ["node_modules"]
}
